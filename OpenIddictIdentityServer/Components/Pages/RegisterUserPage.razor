@page "/register"
@inject NavigationManager NavigationManager
@inject UserManager<ApplicationUser> UserManager

<RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="height: 100vh">
    <RadzenCard Style="width: 400px">
        <RadzenStack AlignItems="AlignItems.Center">
            <RadzenHeading Size="H1" Text="Register" />
        </RadzenStack>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Text="@errorMessage" />
        }

        <RadzenTemplateForm Data="@registerUserModel" TItem="RegisterUserModel" Submit="@HandleRegistration">

            <RadzenStack>
                <RadzenFormField Text="Email" AllowFloatingLabel="false">
                    <ChildContent>
                        <RadzenTextBox @bind-Value="registerUserModel.Email" Name="Email" />
                    </ChildContent>
                    <Helper>
                        <RadzenRequiredValidator Component="Email" Text="Email is required" />
                        <RadzenEmailValidator Component="Email" Text="Invalid email format" />
                    </Helper>
                </RadzenFormField>
                <RadzenFormField Text="Password" AllowFloatingLabel="false">
                    <ChildContent>
                        <RadzenPassword @bind-Value="registerUserModel.Password" Name="Password" />
                    </ChildContent>
                    <Helper>
                        <RadzenRequiredValidator Component="Password" Text="Password is required" />
                        <RadzenRegexValidator Component="Password"
                                              Text="Invalid password! It must have at least 8 characters, including 1 lowercase (a-z), 1 uppercase (A-Z), 1 number (0-9), and 1 special character"
                                              Pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^\da-zA-Z]).{8,}$" />
                    </Helper>
                </RadzenFormField>
                <RadzenButton ButtonType="ButtonType.Submit" Variant="Variant.Flat" Text="Register" ButtonStyle="ButtonStyle.Primary" Disabled="@isLoading" />

                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Center" AlignItems="AlignItems.Center" Gap="4">
                    Already have an account?
                    <RadzenLink Path="/login" Text="Login" />
                </RadzenStack>
            </RadzenStack>


        </RadzenTemplateForm>
    </RadzenCard>
</RadzenStack>

@code {
    private RegisterUserModel registerUserModel = new RegisterUserModel();
    private string errorMessage = string.Empty;
    private bool isLoading = false;

    private async Task HandleRegistration()
    {
        isLoading = true;

        var user = new ApplicationUser
            {
                UserName = registerUserModel.Email,
                Email = registerUserModel.Email
            };

        var result = await UserManager.CreateAsync(user, registerUserModel.Password);
        if (!result.Succeeded)
        {
            errorMessage = string.Join(", ", result.Errors.Select(e => e.Description));
        }

        isLoading = false;

        NavigationManager.NavigateTo("/login");
    }
}